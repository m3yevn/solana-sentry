{
  "version": 2,
  "builds": [
    {
      "src": "src/index.ts",
      "use": "@vercel/node"
    },
    {
      "src": "public/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    { "src": "/query/(.*)", "dest": "src/index.ts" },
    { "src": "/webhook", "dest": "src/index.ts" },
    { "src": "/health", "dest": "src/index.ts" },
    { "src": "/", "dest": "/public/index.html" },
    { "src": "/docs", "dest": "/public/docs.html" },
    { "src": "/(.*)", "dest": "/public/$1" }
  ]
}
